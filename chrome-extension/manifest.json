{
    "manifest_version": 3,
    "name": "Lexify Reader",
    "version": "1.0",
    "description": "Simplify web text instantly with AI for dyslexia-friendly reading.",
    "permissions": [
        "activeTab",
        "scripting",
        "contextMenus"
    ],
    "host_permissions": [
        "<all_urls>",
        "http://localhost:5000/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}